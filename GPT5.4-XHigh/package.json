{
  "name": "flowboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/bootstrap.ts && next dev",
    "dev:e2e": "tsx scripts/dev-e2e.ts",
    "start:e2e": "tsx scripts/start-e2e.ts",
    "build": "tsx scripts/bootstrap.ts && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts"
  },
  "dependencies": {
    "@carbon/charts": "1.27.3",
    "@carbon/charts-react": "1.27.3",
    "@carbon/icons-react": "11.78.0",
    "@carbon/react": "1.105.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@tanstack/react-query": "5.99.0",
    "better-auth": "1.6.2",
    "better-sqlite3": "12.9.0",
    "date-fns": "4.1.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.3",
    "next-swagger-doc": "0.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sass": "1.99.0",
    "swagger-ui-react": "5.32.2",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.6.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "jsdom": "29.0.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
